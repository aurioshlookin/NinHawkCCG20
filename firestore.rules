rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================
    // FUNÇÕES AUXILIARES
    // ========================================================

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 🔒 impede virar admin
    function isNotChangingRole() {
      return request.resource.data.role == resource.data.role;
    }

    // 🔒 limita campos que o usuário pode alterar
    function allowedUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          // gameplay
          'inventory',
          'pullsAvailable',
          'premiumPullsAvailable',
          'claimedAchievements',
          'tradesToday',
          'lastTradeDate',
          'totalTradesCompleted',
          'totalPacksOpened',

          // perfil
          'notifications',
          'sessionId',
          'lastLogin',
          'createdAt'
        ]);
    }

    // ========================================================
    // COLEÇÃO: users
    // ========================================================
    match /users/{userId} {

      allow read: if true;

      allow create: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role != 'admin');

      // 🔥 BALANCEADO: funciona + seguro
      allow update: if isOwner(userId)
        && isNotChangingRole()
        && allowedUserFields();

      allow update, delete: if isAdmin();
    }

    // ========================================================
    // COLEÇÃO: cards
    // ========================================================
    match /cards/{cardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // COLEÇÃO: settings
    // ========================================================
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // COLEÇÃO: trades
    // ========================================================
    match /trades/{tradeId} {

      allow read: if true;

      allow create: if isAuth()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.offerCardId is string
        && request.resource.data.requestTier in ['C', 'B', 'A', 'S', 'SS'];

      allow update: if isAuth()
        && (
          // cancelar própria trade
          (resource.data.fromUserId == request.auth.uid
            && request.resource.data.status == 'cancelled'
            && request.resource.data.fromUserId == resource.data.fromUserId)

          ||

          // aceitar trade
          (resource.data.fromUserId != request.auth.uid
            && request.resource.data.status == 'completed'
            && request.resource.data.acceptedBy == request.auth.uid)
        );

      allow delete: if isAdmin();
    }

    // ========================================================
    // COLEÇÃO: system_logs
    // ========================================================
    match /system_logs/{logId} {

      allow read: if isAdmin();

      // 🔒 bloqueia injection/XSS via log
allow create: if isAuth()
  && request.resource.data.keys().hasOnly(['action', 'timestamp'])
  && request.resource.data.action is string
  && request.resource.data.action.size() < 500
  && request.resource.data.action.matches('^[^<>]*$');

      allow update, delete: if false;
    }

    // ========================================================
    // COLEÇÃO: community
    // ========================================================
    match /community/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // COLEÇÃO: admin_security
    // ========================================================
    match /admin_security/{docId} {
      allow read, write: if false;
    }

    // ========================================================
    // COLEÇÃO: global_stats
    // ========================================================
    match /global_stats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // BANIMENTOS
    // ========================================================
    match /banned_users/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banned_ips/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // DEFAULT: NEGADO
    // ========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
