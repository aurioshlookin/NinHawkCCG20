rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // FUNÇÕES AUXILIARES
    // ============================================================

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Campos que NUNCA podem ser alterados pelo cliente ────────
    // inventory, pullsAvailable e premiumPullsAvailable só podem
    // ser escritos pelas Cloud Functions via Admin SDK (que ignora
    // estas rules). Qualquer tentativa do cliente de tocar nesses
    // campos é bloqueada aqui.
    function notTouchingEconomyFields() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny([
        'inventory',
        'pullsAvailable',
        'premiumPullsAvailable',
        'totalPacksOpened',
        'totalTradesCompleted',
        'tradesToday',
        'lastTradeDate',
        'claimedAchievements'
      ]);
    }

    // 🔒 impede virar admin
    function isNotChangingRole() {
      return !('role' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // Campos permitidos para o cliente atualizar no próprio perfil
    // (apenas metadados não-econômicos)
    function allowedProfileFields() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly([
        'notifications',
        'sessionId',
        'lastLogin',
        'createdAt'
      ]);
    }

    // ============================================================
    // COLEÇÃO: users
    // ============================================================
    match /users/{userId} {

      allow read: if true;

      // Criação: o usuário pode criar o próprio doc, sem role admin
      // e sem campos de economia pré-inflados.
      allow create: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role != 'admin')
        && (!('inventory' in request.resource.data) || request.resource.data.inventory == {})
        && (!('pullsAvailable' in request.resource.data) || request.resource.data.pullsAvailable == 0)
        && (!('premiumPullsAvailable' in request.resource.data) || request.resource.data.premiumPullsAvailable == 0)
        && (!('claimedAchievements' in request.resource.data) || request.resource.data.claimedAchievements == {});

      // Atualização pelo próprio usuário: SOMENTE campos de perfil
      // não-econômicos. Qualquer tentativa de tocar em inventory,
      // pullsAvailable, etc. é rejeitada aqui.
      allow update: if isOwner(userId)
        && isNotChangingRole()
        && notTouchingEconomyFields()
        && allowedProfileFields();

      // Admin pode fazer tudo
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // COLEÇÃO: cards
    // ============================================================
    match /cards/{cardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // COLEÇÃO: settings
    // ============================================================
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // COLEÇÃO: trades
    // ============================================================
    match /trades/{tradeId} {

      allow read: if true;

      // Criação de oferta: somente usuário autenticado pode criar,
      // e os campos econômicos fixos (offerQuantity = 1, status = open)
      // são validados aqui também.
      allow create: if isAuth()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.offerCardId is string
        && request.resource.data.offerQuantity == 1
        && request.resource.data.requestTier in ['C', 'B', 'A', 'S', 'SS']
        && request.resource.data.requestQuantity is int
        && request.resource.data.requestQuantity >= 1
        && request.resource.data.requestQuantity <= 5;

      // NOTA IMPORTANTE sobre trocas:
      // As atualizações de inventário (deduzir/adicionar cartas) e
      // de tradesToday/totalTradesCompleted acontecem DENTRO de uma
      // runTransaction() no cliente via SDK. O SDK do cliente usa
      // as regras abaixo para o documento de TRADE, mas as
      // atualizações dos documentos de USUÁRIO dentro dessa mesma
      // transação são validadas pelas regras do /users acima.
      //
      // Cancelar própria trade (status → cancelled) é permitido.
      // Aceitar trade (status → completed) também é permitido aqui,
      // mas a atualização de inventário é feita via Cloud Function.
      allow update: if isAuth()
        && (
          // cancelar própria trade
          (resource.data.fromUserId == request.auth.uid
            && request.resource.data.status == 'cancelled'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))

          ||

          // aceitar trade (só o status do trade muda aqui;
          // inventário é atualizado pela Cloud Function)
          (resource.data.fromUserId != request.auth.uid
            && resource.data.status == 'open'
            && request.resource.data.status == 'completed'
            && request.resource.data.acceptedBy == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'acceptedBy']))
        );

      allow delete: if isAdmin();
    }

    // ============================================================
    // COLEÇÃO: system_logs
    // ============================================================
    match /system_logs/{logId} {

      allow read: if isAdmin();

      // 🔒 bloqueia injection/XSS via log
      allow create: if isAuth()
        && request.resource.data.keys().hasOnly(['action', 'timestamp'])
        && request.resource.data.action is string
        && request.resource.data.action.size() < 500
        && request.resource.data.action.matches('^[^<>]*$');

      allow update, delete: if false;
    }

    // ============================================================
    // COLEÇÃO: community
    // ============================================================
    match /community/{docId} {
      allow read: if true;
      // Leaderboard: admin pode sempre escrever.
      // O sync do leaderboard também é feito pela Cloud Function
      // de abertura de pacote (que usa Admin SDK).
      allow write: if isAdmin();
    }

    // ============================================================
    // COLEÇÃO: admin_security
    // ============================================================
    match /admin_security/{docId} {
      allow read, write: if false;
    }

    // ============================================================
    // COLEÇÃO: global_stats
    // ============================================================
    match /global_stats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // BANIMENTOS
    // ============================================================
    match /banned_users/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banned_ips/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // DEFAULT: NEGADO
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
